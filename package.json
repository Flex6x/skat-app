{
  "name": "skat-multiplayer-server",
  "version": "1.0.0",
  "description": "Multiplayer Skat card game server with Socket.io",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node --watch server.js",
